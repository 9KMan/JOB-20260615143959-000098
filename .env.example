# =============================================================================
# Environment Variables Template
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=scraper-framework
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# PostgreSQL Database
# -----------------------------------------------------------------------------
POSTGRES_DB=scraper_db
POSTGRES_USER=scraper
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# PGBouncer Connection Pooler
# -----------------------------------------------------------------------------
PGBOUNCER_PORT=6432

# -----------------------------------------------------------------------------
# RabbitMQ Message Broker
# -----------------------------------------------------------------------------
RABBITMQ_USER=scraper
RABBITMQ_PASSWORD=your_rabbitmq_password_here
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# -----------------------------------------------------------------------------
# Worker Configuration
# -----------------------------------------------------------------------------
# Prefetch count: 1 job per worker at a time for reliability
WORKER_PREFETCH_COUNT=1
# Heartbeat interval in seconds
WORKER_HEARTBEAT_INTERVAL=30
# Maximum retry attempts before sending to DLQ
WORKER_MAX_RETRIES=5
# Base retry delay in seconds (exponential backoff)
WORKER_RETRY_DELAY=30
# Job timeout in seconds
WORKER_JOB_TIMEOUT=180
# Page load timeout in seconds
WORKER_PAGE_LOAD_TIMEOUT=60
# Navigation timeout in seconds
WORKER_NAVIGATION_TIMEOUT=60

# -----------------------------------------------------------------------------
# Oxylabs Proxy Configuration
# -----------------------------------------------------------------------------
# Get your credentials from https://oxylabs.io
OXYLABS_USERNAME=your_oxylabs_username
OXYLABS_PASSWORD=your_oxylabs_password
# Default country for proxy rotation (ISO 3166-1 alpha-2)
OXYLABS_DEFAULT_COUNTRY=US
# Session timeout in seconds (for sticky sessions)
OXYLABS_SESSION_TIMEOUT=300
# Proxy pool size per worker
OXYLABS_POOL_SIZE=10

# -----------------------------------------------------------------------------
# LLM Configuration (OpenAI)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.1

# -----------------------------------------------------------------------------
# LLM Configuration (Anthropic - Alternative)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-sonnet-20240229
ANTHROPIC_MAX_TOKENS=4096

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
API_PORT=8000
API_WORKERS=4
# JWT Configuration
JWT_SECRET_KEY=generate-a-secure-random-string-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60
# CORS Configuration (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# -----------------------------------------------------------------------------
# Prometheus Metrics
# -----------------------------------------------------------------------------
PROMETHEUS_PORT=9090

# -----------------------------------------------------------------------------
# Grafana Dashboards
# -----------------------------------------------------------------------------
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin123

# -----------------------------------------------------------------------------
# Circuit Breaker Configuration
# -----------------------------------------------------------------------------
# Failure threshold: number of failures before opening circuit
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
# Recovery timeout: seconds before attempting recovery
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=30
# Half-open max calls: number of calls allowed in half-open state
CIRCUIT_BREAKER_HALF_OPEN_MAX_CALLS=3

# -----------------------------------------------------------------------------
# Database Connection Pool (via SQLAlchemy)
# -----------------------------------------------------------------------------
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_FORMAT=json
LOG_DIR=/app/logs
LOG_MAX_BYTES=104857600
LOG_BACKUP_COUNT=10

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
ENABLE_LLM_POST_PROCESSING=true
ENABLE_PROXY_HEALTH_CHECKS=true
ENABLE_WORKER_METRICS=true
ENABLE_API_METRICS=true
